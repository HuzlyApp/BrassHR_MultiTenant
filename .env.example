# Public browser-safe values (DEVELOPMENT by default for local clones)
# Prefer .env.development.example → .env.local for localhost.
# Production values belong only in the hosting provider Production env.
NEXT_PUBLIC_SUPABASE_URL=https://mgucromvpnxntwyssltd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_PLATFORM_ENFORCE=

# Server-only Supabase secrets (development service role for local)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=

# Optional Expo / server aliases (resolved by lib/supabase-env.ts)
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Redis cache and rate limiting
REDIS_URL=
REDIS_TOKEN=
CACHE_ENABLED=false
CACHE_DEFAULT_TTL_SECONDS=300

# Rate limit tuning
RATE_LIMIT_AUTH_PER_15_MIN=10
RATE_LIMIT_EMAIL_CHECK_PER_HOUR=30
RATE_LIMIT_UPLOADS_PER_HOUR=20
RATE_LIMIT_AI_PER_HOUR=20
RATE_LIMIT_SIGNING_PER_HOUR=20
RATE_LIMIT_SEARCH_PER_MINUTE=60
RATE_LIMIT_PUBLIC_API_PER_MINUTE=60
RATE_LIMIT_WEBHOOKS_PER_MINUTE=120

# Third-party server-only secrets
RESEND_API_KEY=
RESEND_FROM_DOMAIN=brasshr.com
RESEND_FROM_DISPLAY_NAME=Brass HR
DEFAULT_SUPPORT_EMAIL=
RESEND_WEBHOOK_SECRET=
RESEND_ALLOW_UNSIGNED_WEBHOOKS=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_SERVICE_SID=
GROK_API_KEY=
XAI_API_KEY=
MAPBOX_ACCESS_TOKEN=
SIGNEASY_API_KEY=
SIGNEASY_ACCESS_TOKEN=

# Firma.dev e-sign (onboarding agreements)
FIRMA_API_KEY=
FIRMA_WEBHOOK_SECRET=
FIRMA_WORKSPACE_ID=

# Zoho Recruit CRM sync only (not used for applicant agreement signing)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Local development only. Never enable in production.
DEV_ADMIN_AUTH_BYPASS=false
TWILIO_ALLOW_UNSIGNED_WEBHOOKS=false
